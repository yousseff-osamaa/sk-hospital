{
  "buildCommand": "node node_modules/@angular/cli/bin/ng.js build",
  "outputDirectory": "dist/hospital-app/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://skuh-backend.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
